\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Characteristics of the three benchmark datasets used for evaluation. (a) MMLU-Hard: 2,197 examples from 10 difficult subjects, mean difficulty 0.7, contestedness 0.6. (b) GPQA: 448 graduate-level questions, mean difficulty 0.66, contestedness 0.7. (c) TruthfulQA: 817 questions testing truthfulness, mean difficulty 0.5, contestedness 0.43. Box plots show the distribution of difficulty and contestedness scores for each dataset.}}{7}{figure.3}\protected@file@percent }
\newlabel{fig:fig3}{{3}{7}{Characteristics of the three benchmark datasets used for evaluation. (a) MMLU-Hard: 2,197 examples from 10 difficult subjects, mean difficulty 0.7, contestedness 0.6. (b) GPQA: 448 graduate-level questions, mean difficulty 0.66, contestedness 0.7. (c) TruthfulQA: 817 questions testing truthfulness, mean difficulty 0.5, contestedness 0.43. Box plots show the distribution of difficulty and contestedness scores for each dataset}{figure.3}{}}
